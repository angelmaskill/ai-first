{
  "name": "ai-first",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first vibe coding scaffold control plane",
  "type": "module",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "npx tsc --noEmit",
    "dispatch": "npx tsx src/core/harness/subagent-dispatcher.ts",
    "test": "vitest run",
    "typecheck": "npx tsc --noEmit",
    "lint": "npx eslint src/ --ext .ts",
    "format:check": "npx prettier --check 'src/**/*.ts'",
    "format": "npx prettier --write 'src/**/*.ts'",
    "check": "npm run typecheck && npm run test && npm run lint && npm run format:check",
    "data:sync": "npx tsx scripts/generate-frontend-data.ts",
    "dev": "npm run data:sync && npx vite",
    "frontend:dev": "npm run data:sync && npx vite",
    "frontend:build": "npm run data:sync && npx vite build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
